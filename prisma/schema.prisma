generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  password             String
  plainPassword        String?
  role                 UserRole              @default(cashier)
  permissions          String[]              @default([])
  isActive             Boolean               @default(true)
  floorId              String?
  assignedCategories   String[]              @default([])
  canManageReception   Boolean               @default(false)
  lastLoginAt          DateTime?
  lastLogoutAt         DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  fixedAssetDismissals FixedAssetDismissal[] @relation("fixed_asset_dismissed_by")
  roomServiceFloors    Floor[]               @relation("floor_room_service_cashier")
  createdOrders        Order[]               @relation("orders_created_by")
  stockRestocks        StockRestockEntry[]
  storeLogs            StoreLog[]
  transfersHdl         TransferRequest[]     @relation("transfer_handled_by")
  transfersReq         TransferRequest[]     @relation("transfer_requested_by")
  floor                Floor?                @relation("user_floor", fields: [floorId], references: [id])
}

model Floor {
  id                   String    @id @default(cuid())
  floorNumber          String    @unique
  description          String?
  order                Int       @default(0)
  isActive             Boolean   @default(true)
  isVIP                Boolean   @default(false)
  type                 FloorType @default(standard)
  status               String    @default("active")
  roomServiceCashierId String?
  roomServiceMenuTier  MenuTier  @default(standard)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  roomServiceCashier   User?     @relation("floor_room_service_cashier", fields: [roomServiceCashierId], references: [id])
  orders               Order[]
  rooms                Room[]
  tables               Table[]
  users                User[]    @relation("user_floor")
}

model Table {
  id          String      @id @default(cuid())
  tableNumber String      @unique
  name        String?
  floorId     String?
  isVIP       Boolean     @default(false)
  status      TableStatus @default(active)
  capacity    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      Order[]
  floor       Floor?      @relation(fields: [floorId], references: [id])
}

model MenuItem {
  id               String             @id @default(cuid())
  menuId           String             @unique
  tier             MenuTier           @default(standard)
  name             String
  mainCategory     MainCategory       @default(Food)
  category         String?
  price            Float
  available        Boolean            @default(true)
  description      String?
  image            String?
  preparationTime  Int                @default(10)
  reportUnit       String?
  reportQuantity   Float?
  distributions    String[]           @default([])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  stockItemId      String?
  stockConsumption Float?
  stockItem        Stock?             @relation(fields: [stockItemId], references: [id])
  recipe           RecipeIngredient[]
}

model RecipeIngredient {
  id               String   @id @default(cuid())
  menuItemId       String
  stockItemId      String
  stockItemName    String
  quantityRequired Float
  unit             String
  menuItem         MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  stockItem        Stock    @relation(fields: [stockItemId], references: [id])

  @@index([menuItemId])
  @@index([stockItemId])
}

model Order {
  id                   String      @id @default(cuid())
  orderNumber          String      @unique
  totalAmount          Float
  tax                  Float       @default(0)
  subtotal             Float       @default(0)
  status               OrderStatus @default(pending)
  paymentMethod        String      @default("cash")
  customerName         String?
  tableNumber          String
  batchNumber          String?
  tableId              String?
  floorId              String?
  floorNumber          String?
  distributions        String[]    @default([])
  createdById          String?
  kitchenAcceptedAt    DateTime?
  readyAt              DateTime?
  servedAt             DateTime?
  delayMinutes         Int?
  thresholdMinutes     Int?
  totalPreparationTime Int?
  isDeleted            Boolean     @default(false)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  createdBy            User?       @relation("orders_created_by", fields: [createdById], references: [id])
  floor                Floor?      @relation(fields: [floorId], references: [id])
  table                Table?      @relation(fields: [tableId], references: [id])
  items                OrderItem[]

  @@index([status, createdAt(sort: Desc)])
  @@index([floorId])
  @@index([createdById])
  @@index([tableNumber])
  @@index([isDeleted])
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  menuItemId      String?
  menuId          String?
  name            String
  quantity        Int
  price           Float
  status          OrderStatus   @default(pending)
  modifiers       String[]      @default([])
  notes           String?
  category        String?
  mainCategory    MainCategory?
  menuTier        MenuTier      @default(standard)
  initialStatus   String?
  preparationTime Int?
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([category])
}

model Stock {
  id                   String              @id @default(cuid())
  name                 String
  category             String
  quantity             Float               @default(0)
  storeQuantity        Float               @default(0)
  unit                 String
  unitType             StockUnitType       @default(count)
  minLimit             Float               @default(0)
  storeMinLimit        Float               @default(0)
  averagePurchasePrice Float               @default(0)
  unitCost             Float               @default(0)
  trackQuantity        Boolean             @default(true)
  showStatus           Boolean             @default(true)
  status               StockStatus         @default(active)
  totalPurchased       Float               @default(0)
  totalConsumed        Float               @default(0)
  totalInvestment      Float               @default(0)
  sellUnitEquivalent   Float               @default(1)
  isVIP                Boolean             @default(false)
  vipLevel             Int                 @default(1)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  menuItems            MenuItem[]
  recipes              RecipeIngredient[]
  restockHistory       StockRestockEntry[]
  storeLogs            StoreLog[]
  transferRequests     TransferRequest[]
}

model StockRestockEntry {
  id                String   @id @default(cuid())
  stockId           String
  date              DateTime @default(now())
  quantityAdded     Float
  totalPurchaseCost Float
  unitCostAtTime    Float
  notes             String?
  restockedById     String?
  restockedBy       User?    @relation(fields: [restockedById], references: [id])
  stock             Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId])
  @@index([date(sort: Desc)])
}

model Category {
  id          String       @id @default(cuid())
  name        String
  type        CategoryType
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, type])
}

model Settings {
  id          String       @id @default(cuid())
  key         String       @unique
  value       String       @default("")
  type        SettingsType @default(string)
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model FixedAsset {
  id            String                @id @default(cuid())
  name          String
  category      String                @default("General")
  quantity      Float                 @default(1)
  unitPrice     Float                 @default(0)
  totalValue    Float                 @default(0)
  totalInvested Float                 @default(0)
  purchaseDate  DateTime              @default(now())
  status        FixedAssetStatus      @default(active)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  dismissals    FixedAssetDismissal[]

  @@index([status])
  @@index([category])
}

model FixedAssetDismissal {
  id            String     @id @default(cuid())
  fixedAssetId  String
  date          DateTime   @default(now())
  quantity      Float
  reason        String
  valueLost     Float
  dismissedById String?
  dismissedBy   User?      @relation("fixed_asset_dismissed_by", fields: [dismissedById], references: [id])
  fixedAsset    FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([fixedAssetId])
  @@index([date(sort: Desc)])
}

model OperationalExpense {
  id          String   @id @default(cuid())
  date        DateTime
  name        String?
  category    String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date(sort: Desc)])
  @@index([category])
}

model Room {
  id                  String     @id @default(cuid())
  roomNumber          String     @unique
  name                String?
  floorId             String
  type                RoomType   @default(standard)
  category            String     @default("Standard")
  price               Float      @default(0)
  status              RoomStatus @default(available)
  isActive            Boolean    @default(true)
  description         String?
  roomServiceMenuTier MenuTier   @default(standard)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  floor               Floor      @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([floorId])
  @@index([status])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  price       Float    @default(0)
  unit        String   @default("per request")
  isAvailable Boolean  @default(true)
  icon        String   @default("🛎️")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model ReceptionRequest {
  id               String                 @id @default(cuid())
  guestName        String
  faydaId          String?
  phone            String?
  idPhotoFront     String?
  idPhotoBack      String?
  photoUrl         String?
  floorId          String?
  roomNumber       String?
  roomPrice        Float?
  inquiryType      String
  checkIn          String?
  checkOut         String?
  checkInTime      String?
  checkOutTime     String?
  guests           String?
  paymentMethod    String?
  chequeNumber     String?
  paymentReference String?
  transactionUrl   String?
  notes            String?
  status           ReceptionRequestStatus @default(CHECKIN_PENDING)
  submittedBy      String?
  reviewedBy       String?
  reviewNote       String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([submittedBy])
  @@index([roomNumber])
}

model TransferRequest {
  id            String         @id @default(cuid())
  stockId       String
  quantity      Float
  status        TransferStatus @default(pending)
  requestedById String
  handledById   String?
  denialReason  String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  handledBy     User?          @relation("transfer_handled_by", fields: [handledById], references: [id])
  requestedBy   User           @relation("transfer_requested_by", fields: [requestedById], references: [id])
  stock         Stock          @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([status, createdAt(sort: Desc)])
  @@index([requestedById])
}

model StoreLog {
  id           String       @id @default(cuid())
  stockId      String
  type         StoreLogType
  quantity     Float
  unit         String
  pricePerUnit Float?
  totalPrice   Float?
  userId       String
  notes        String?
  date         DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  stock        Stock        @relation(fields: [stockId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([date(sort: Desc), type])
  @@index([stockId])
}

model DailyExpense {
  id            String   @id @default(cuid())
  date          DateTime @unique
  otherExpenses Float    @default(0)
  items         Json     @default("[]")
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  field       String?
  oldValue    String?
  newValue    String?
  performedBy String
  timestamp   DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([timestamp(sort: Desc)])
}

enum UserRole {
  admin
  cashier
  chef
  bar
  display
  store_keeper
  reception
  custom
  super_admin
}

enum FloorType {
  standard
  vip
}

enum MenuTier {
  standard
  vip1
  vip2
}

enum MainCategory {
  Food
  Drinks
}

enum TableStatus {
  active
  inactive
  maintenance
}

enum OrderStatus {
  unconfirmed
  pending
  preparing
  ready
  served
  completed
  cancelled
}

enum StockUnitType {
  weight
  volume
  count
}

enum StockStatus {
  active
  finished
  out_of_stock
}

enum CategoryType {
  menu
  stock
  fixed_asset
  expense
  room
  service
  vip1_menu
  vip2_menu
  distribution
}

enum SettingsType {
  string
  url
  boolean
  number
}

enum FixedAssetStatus {
  active
  partially_dismissed
  fully_dismissed
}

enum TransferStatus {
  pending
  approved
  denied
}

enum StoreLogType {
  PURCHASE
  TRANSFER_OUT
  ADJUSTMENT
}

enum RoomType {
  standard
  deluxe
  suite
  other
}

enum RoomStatus {
  available
  occupied
  maintenance
  dirty
}

enum ReceptionRequestStatus {
  CHECKIN_PENDING
  CHECKIN_APPROVED
  EXTEND_PENDING
  CHECKOUT_PENDING
  CHECKOUT_APPROVED
  CHECKED_OUT
  REJECTED
  pending
  guests
  rejected
  check_in
  check_out
  ACTIVE
}
